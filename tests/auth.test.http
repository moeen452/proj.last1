// tests/auth.test.http
### Admin API Tests - Authentication Module
### الاختبارات التلقائية لمودول المصادقة

@baseUrl = http://localhost:3000/api/v1
@email = test_user_@timestamp@.com
@password = Password123
@fullName = Test User

######################################
# 1️⃣ REGISTER - تسجيل حساب جديد
######################################

### ✅ تسجيل ناجح
POST {{baseUrl}}/auth/register
Content-Type: application/json
Accept-Language: ar

{
  "fullName": "{{fullName}}",
  "email": "user_test_001@gmail.com",
  "password": "{{password}}"
}

### ❌ خطأ: إيميل موجود مسبقاً
POST {{baseUrl}}/auth/register
Content-Type: application/json
Accept-Language: ar

{
  "fullName": "Test User 2",
  "email": "user_test_001@gmail.com",
  "password": "{{password}}"
}

### ❌ خطأ: كلمة المرور قصيرة
POST {{baseUrl}}/auth/register
Content-Type: application/json
Accept-Language: ar

{
  "fullName": "Test User 3",
  "email": "user_test_003@gmail.com",
  "password": "123"
}

######################################
# 2️⃣ VERIFY EMAIL - تأكيد البريد
######################################

### 📝 ملاحظة: انسخ الرابط من الـ terminal
### URL format: /auth/verify-email?token=xxx

GET {{baseUrl}}/auth/verify-email?token=PASTE_TOKEN_HERE
Accept-Language: ar

######################################
# 3️⃣ LOGIN - تسجيل الدخول
######################################

### ✅ دخول ناجح
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept-Language: ar

{
  "email": "user_test_001@gmail.com",
  "password": "{{password}}"
}

### ❌ خطأ: بيانات خاطئة
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept-Language: ar

{
  "email": "user_test_001@gmail.com",
  "password": "WrongPassword123"
}

######################################
# 4️⃣ GET ME - بيانات المستخدم
######################################

### ✅ جلب بيانات المستخدم
GET {{baseUrl}}/auth/me
Authorization: Bearer PASTE_ACCESS_TOKEN_HERE
Accept-Language: ar

######################################
# 5️⃣ REFRESH - تجديد التوكن
######################################

### ✅ تجديد الـ token
POST {{baseUrl}}/auth/refresh
Cookie: refreshToken=PASTE_REFRESH_TOKEN_HERE
Accept-Language: ar

######################################
# 6️⃣ LOGOUT - تسجيل الخروج
######################################

### ✅ خروج ناجح
POST {{baseUrl}}/auth/logout
Authorization: Bearer PASTE_ACCESS_TOKEN_HERE
Accept-Language: ar
