############################################
# 🧪 اختبار API الكامل - Phase 1
# تاريخ: 2026-03-08
# الملف: test.http (REST Client)
############################################

@baseUrl = http://localhost:3000/api/v1

############################################
# ✅ اختبارات المرحلة 1 + 2
############################################

### 1. اختبار السيرفر
GET http://localhost:3000/
Accept-Language: ar

### 2. REGISTER - التسجيل الجديد
POST {{baseUrl}}/auth/register
Content-Type: application/json
Accept-Language: ar

{
  "fullName": "محمد أحمد",
  "email": "moeen_test_001@gmail.com",
  "password": "Password123"
}

### 3. VERIFY EMAIL - تأكيد الإيميل
### ضع الرمز من Terminal بدل TOKEN
GET {{baseUrl}}/auth/verify-email?token=PASTE_TOKEN_HERE
Accept-Language: ar

### 4. LOGIN - تسجيل الدخول
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept-Language: ar

{
  "email": "moeen_test_001@gmail.com",
  "password": "Password123"
}

### 5. GET ME - بيانات المستخدم
GET {{baseUrl}}/auth/me
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywiZW1haWwiOiJtb2hzaW5fNTE1MTAxNzMwQHRlc3QuY29tIiwicm9sZSI6Im93bmVyIiwiaWF0IjoxNzcyOTgzMDA1LCJleHAiOjE3NzI5ODM5MDV9.Adpe-sa7Ajt1oe00oV9c0tdEOkloInlNOoxllIYEfhU
Accept-Language: ar

### 6. REFRESH TOKEN
POST {{baseUrl}}/auth/refresh
Accept-Language: ar

### 7. LOGOUT
POST {{baseUrl}}/auth/logout
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywiZW1haWwiOiJtb2hzaW5fNTE1MTAxNzMwQHRlc3QuY29tIiwicm9sZSI6Im93bmVyIiwiaWF0IjoxNzcyOTgzMDA1LCJleHAiOjE3NzI5ODM5MDV9.Adpe-sa7Ajt1oe00oV9c0tdEOkloInlNOoxllIYEfhU
Accept-Language: ar

### 8. CREATE STARTUP
POST {{baseUrl}}/startups
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywiZW1haWwiOiJtb2hzaW5fNTE1MTAxNzMwQHRlc3QuY29tIiwicm9sZSI6Im93bmVyIiwiaWF0IjoxNzcyOTgzMDA1LCJleHAiOjE3NzI5ODM5MDV9.Adpe-sa7Ajt1oe00oV9c0tdEOkloInlNOoxllIYEfhU
Accept-Language: ar

{
  "name": "تطبيق التوصيل",
  "description": "أفضل تطبيق توصيل في المدينة"
}

### 9. GET MY STARTUP
GET {{baseUrl}}/startups/my
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywiZW1haWwiOiJtb2hzaW5fNTE1MTAxNzMwQHRlc3QuY29tIiwicm9sZSI6Im93bmVyIiwiaWF0IjoxNzcyOTgzMDA1LCJleHAiOjE3NzI5ODM5MDV9.Adpe-sa7Ajt1oe00oV9c0tdEOkloInlNOoxllIYEfhU
Accept-Language: ar

### 10. GET ALL STARTUPS
GET {{baseUrl}}/startups?page=1&limit=10
Accept-Language: ar

### 11. APPROVE STARTUP (Admin only)
PATCH {{baseUrl}}/startups/1/approve
Authorization: Bearer ADMIN_TOKEN_HERE
Accept-Language: ar

############################################
# ❌ اختبارات الأخطاء
############################################

### Error: Duplicate Email
POST {{baseUrl}}/auth/register
Content-Type: application/json
Accept-Language: ar

{
  "fullName": "أحمد محمد",
  "email": "duplicate@test.com",
  "password": "Password123"
}

### Error: Wrong Password
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept-Language: ar

{
  "email": "moeen_test_001@gmail.com",
  "password": "WrongPassword"
}

### Error: No Token
GET {{baseUrl}}/auth/me
Accept-Language: ar
